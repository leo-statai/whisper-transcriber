# Modelo do Whisper (via faster-whisper / CTranslate2)
#   tiny | base | small | medium | large-v3 | large-v3-turbo
WHISPER_MODEL=large-v3

# Precisão de cálculo na GPU
#   float16 | int8_float16 | int8 (CPU fallback)
WHISPER_COMPUTE_TYPE=float16

# Beam size do decoder (5 = bom equilíbrio qualidade/velocidade)
WHISPER_BEAM_SIZE=5

# Filtro VAD (Voice Activity Detection) — recomendado para arquivos longos
WHISPER_VAD_FILTER=true

# Idioma forçado (vazio = autodetect). Ex: pt, en, es
WHISPER_LANGUAGE=

# Concorrência do worker ARQ (1 para GPU dedicada)
WORKER_CONCURRENCY=1
